{
  "name": "flashback-ts",
  "version": "1.0.0",
  "description": "REminiscence README Release version: 0.4.6 -------------------------------------------------------------------------------",
  "main": "src/app/main.ts",
  "dependencies": {
    "fuse-box": "^4.0.0",
    "ts-node": "^9.1.1"
  },
  "devDependencies": {},
  "scripts": {
    "test": "node --require ts-node/register/transpile-only --test test/**/*.test.js",
    "build:audio-worklet": "tsc src/audio/audio-processors.ts --target es2019 --module esnext --outDir src/audio",
    "dev": "npm run build:audio-worklet && npm run check:room-png-assets && npm run check:switch-door-platforms && ts-node fuse.ts",
    "build": "rm -Rf dist && npm run build:audio-worklet && ts-node fuse-prod.ts && mkdir -p dist/js && cp src/audio/audio-processors.js dist/js/processors.js",
    "check": "npm run check:ts && npm run check:room-png-assets && npm run check:switch-door-platforms",
    "check:ts": "tsc -p tsconfig.json --noEmit",
    "check:room-png-assets": "ts-node --transpile-only ./src/tools/debugger/check-room-png-assets.ts",
    "check:switch-door-platforms": "ts-node --transpile-only ./src/tools/debugger/check-switch-door-platforms.ts",
    "export:ct-adj": "ts-node --transpile-only ./src/tools/debugger/export-ct-adjacency-table.ts",
    "export:ct-adj:level": "ts-node --transpile-only ./src/tools/debugger/export-ct-adjacency-level.ts",
    "export:ct-grid:level-room": "ts-node --transpile-only ./src/tools/debugger/export-ct-grid-level-room.ts",
    "export:ct-grid:merged-png": "ts-node --transpile-only ./src/tools/debugger/export-level-grid-merged-png.ts",
    "rebuild:adjacency:json:from-txt": "ts-node --transpile-only ./src/tools/level-generator/rebuild-adjacency-json-from-txt.ts",
    "export:ct-grid:all": "ts-node --transpile-only ./src/tools/debugger/export-ct-grid-all.ts",
    "export:ct:all": "ts-node --transpile-only ./src/tools/debugger/export-ct-all.ts",
    "export:sprite:image": "ts-node --transpile-only ./src/tools/debugger/export-sprite-image.ts",
    "rebuild:ct:from-txt": "ts-node --transpile-only ./src/tools/level-generator/rebuild-ct-from-txt.ts",
    "export:pge:json": "ts-node --transpile-only ./src/tools/debugger/export-pge-json.ts",
    "export:obj:json": "ts-node --transpile-only ./src/tools/debugger/export-obj-json.ts",
    "export:tbn:json": "ts-node --transpile-only ./src/tools/debugger/export-tbn-json.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/warpdesign/flashback-js.git"
  },
  "author": "Nicolas Ramz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/warpdesign/flashback-js/issues"
  },
  "homepage": "https://github.com/warpdesign/flashback-js#readme"
}
